<Window x:Class="Tetrahedron_Sierpinski.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sierpinski 3D" Height="800" Width="1000"
        MouseMove="Window_MouseMove"
        MouseWheel="Window_MouseWheel"
        MouseDown="Window_MouseDown"
        MouseUp="Window_MouseUp">
    <Grid Background="LightGray">
        <Viewport3D Name="viewport">
            <Viewport3D.Camera>
                <PerspectiveCamera x:Name="camera" Position="0,0,12" LookDirection="0,0,-12" UpDirection="0,1,0"/>
            </Viewport3D.Camera>
        </Viewport3D>

        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="#88000000" CornerRadius="10" Margin="20">
            <StackPanel Orientation="Horizontal" Margin="10">
                <Label Content="Max Level:" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Name="maxLevelTextBox" Width="40" Text="5" VerticalAlignment="Center" Margin="5"/>
                <Button Content="Ustaw Max" Click="SetMax_Click" Width="80" Margin="5"/>

                <Label Content="Poziom:" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <Slider Name="levelSlider" Minimum="0" Maximum="5" Width="200" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="LevelSlider_ValueChanged" VerticalAlignment="Center" Margin="5"/>

                <Button Content="Start" Click="Start_Click" Width="60" Margin="5"/>
                <Button Content="Stop" Click="Stop_Click" Width="60" Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>